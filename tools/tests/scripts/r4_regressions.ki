# r4_regressions.ki — regression tests for bugs found in the r4 audit sweep.
#   P0  tensor.einsum with a repeated OUTPUT label overran the output buffer (heap overflow).
#   P2  json.loads silently accepted malformed numbers (e.g. "1.5e" -> 1.5, truncated).
var io = import("io")
var T = import("tensor")
var json = import("json")

var n = 0
var ok = Function(c, m):
    assert c, m
    n = n + 1
var raises = Function(f):
    try:
        discard f()
        return False
    catch:
        return True

# --- P0: einsum repeated output label now raises (was a heap-buffer-overflow / segfault) ---
ok(raises(Function(): return T.einsum("ii->ii", T.Tensor([[1, 2], [3, 4]]))), "einsum ii->ii raises")
ok(raises(Function(): return T.einsum("i->ii", T.Tensor([1, 2, 3]))), "einsum i->ii raises")
ok(raises(Function(): return T.einsum("i->iii", T.Tensor([1, 2]))), "einsum i->iii raises")
ok(raises(Function(): return T.einsum("ij->jji", T.Tensor([[1, 2, 3], [4, 5, 6]]))), "einsum ij->jji raises")
# valid einsum forms are unaffected
ok(T.einsum("ii->", T.Tensor([[1, 2], [3, 4]])).item() == 5.0, "einsum trace still works")
ok(T.einsum("ij->ji", T.Tensor([[1, 2], [3, 4]])).tolist() == [[1.0, 3.0], [2.0, 4.0]], "einsum transpose still works")
ok(T.einsum("ij->", T.Tensor([[1, 2], [3, 4]])).item() == 10.0, "einsum full sum still works")

# --- P2: json.loads rejects malformed numbers per the JSON grammar ---
ok(raises(Function(): return json.loads("1.5e")), "json 1.5e raises")
ok(raises(Function(): return json.loads("1e")), "json 1e raises")
ok(raises(Function(): return json.loads("1.")), "json 1. raises")
ok(raises(Function(): return json.loads("1.e5")), "json 1.e5 raises")
ok(raises(Function(): return json.loads("1e+")), "json 1e+ raises")
ok(raises(Function(): return json.loads("01")), "json leading-zero 01 raises")
ok(raises(Function(): return json.loads("00")), "json leading-zero 00 raises")
ok(raises(Function(): return json.loads("-01")), "json leading-zero -01 raises")
# valid numbers still parse exactly
ok(json.loads("1.5e10") == 1.5e10, "json 1.5e10 valid")
ok(json.loads("0.5") == 0.5, "json 0.5 valid")
ok(json.loads("-0") == 0, "json -0 valid")
ok(json.loads("0") == 0, "json 0 valid")
ok(json.loads("1e10") == 1e10, "json 1e10 valid")
ok(json.loads("[1, 2.5, -3.0e2]") == [1, 2.5, -300.0], "json number array valid")

io.print("r4_regressions: " + String(n) + " checks passed")
