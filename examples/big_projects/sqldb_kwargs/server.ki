# A networked SQL server written in pure Kirito. It speaks a tiny newline-framed text protocol:
#   - the client sends one request line: a JSON object {"sql": "..."} terminated by '\n'
#   - the server replies with one JSON object line:
#       {"ok": true, "type": "...", ...}   on success
#       {"ok": false, "error": "..."}      on any SQL/parse/lex error
# One shared in-memory Database persists for the server's lifetime, so connections see each other's
# writes (a single-process, sequential server — no threads, matching Kirito's model).
#
# Run:  ki --lib lib server.ki [host] [port]
#   default host 127.0.0.1, port 5433. Prints "LISTENING <host> <port>" once ready (the test
#   harness waits for that line), then serves until it receives {"sql": "__shutdown__"}.

# Keyword-argument edition: every call passes its arguments by name.
var net = import(name = "net")
var io = import(name = "io")
var json = import(name = "json")
var eng = import(name = "sql_engine")

var host = "127.0.0.1"
var port = 5433
if len(x = arglist) >= 1:
    host = arglist[0]
if len(x = arglist) >= 2:
    port = Integer(x = arglist[1])

var db = eng.Database()

# A buffered line reader over a connection: recv in chunks and hand back one '\n'-terminated line
# at a time (leftover bytes are retained for the next call). Reading a byte at a time would make a
# large request thousands of syscalls; this keeps it proportional to the data. Returns None at EOF.
class LineReader:
    var _init_ = Function(self, conn):
        self._conn = conn
        self._buf = ""
    var read_line = Function(self):
        while True:
            var nl = self._buf.find(sub = "\n")
            if nl >= 0:
                var line = self._buf[0:nl]
                self._buf = self._buf[nl + 1:]
                return line
            var chunk = self._conn.recv(size = 8192).decode(encoding = "latin-1")   # Bytes -> text
            if len(x = chunk) == 0:
                if len(x = self._buf) == 0:
                    return None
                var rest = self._buf
                self._buf = ""
                return rest
            self._buf = self._buf + chunk

# Turn a result Dict from the engine into a plain JSON-serializable Dict (it already is — engine
# results use only Dicts/Lists/Strings/Integers/Bools/None), so this is a passthrough with a guard.
var handle_sql = Function(sql : String):
    try:
        var result = db.run(sql = sql)
        return result
    catch as e:
        return {"ok": False, "error": String(x = e)}

var srv = net.Socket()
srv.bind(host = host, port = port)
srv.listen(backlog = 16)
io.print("LISTENING " + host + " " + String(x = port))

var running = True
while running:
    var conn = srv.accept()
    # Serve every request on this connection until the client disconnects.
    var reader = LineReader(conn = conn)
    var open = True
    while open:
        var line = reader.read_line()
        if line == None:
            open = False
        else:
            var reply = None
            var stripped = line.strip()
            if len(x = stripped) == 0:
                reply = {"ok": False, "error": "empty request"}
            else:
                # Parse the request envelope. A malformed envelope is reported, never crashes.
                var req = None
                var bad = False
                try:
                    req = json.parse(text = stripped)
                catch as e:
                    bad = True
                    reply = {"ok": False, "error": "bad request JSON: " + String(x = e)}
                if not bad:
                    if type(x = req) != "Dict" or "sql" not in req:
                        reply = {"ok": False, "error": "request must be a JSON object with a 'sql' field"}
                    elif req["sql"] == "__shutdown__":
                        reply = {"ok": True, "type": "shutdown"}
                        running = False
                        open = False
                    else:
                        reply = handle_sql(sql = req["sql"])
            discard conn.send(data = json.dumps(value = reply) + "\n")
    conn.close()

srv.close()
io.print("STOPPED")
