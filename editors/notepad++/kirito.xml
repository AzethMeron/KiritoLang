<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Kirito syntax highlighting for Notepad++ (User Defined Language).

  Install:  Notepad++  ->  Language menu  ->  User Defined Language  ->  Define your language...
            ->  Import...  ->  pick this file  ->  restart Notepad++.
  Then any .ki file is highlighted automatically (or pick "Kirito" from the Language menu).

  No plugin is required — UDL is built into Notepad++. Folding is brace/indent based and limited
  under UDL; for richer folding/IntelliSense use the VS Code grammar in ../vscode/.

  THEME-AGNOSTIC BY DESIGN. No style sets a background colour, so the editor's own background shows
  through — the highlighting looks right on BOTH a light and a dark Notepad++ theme. Neutral tokens
  (plain identifiers, operators, punctuation) also omit a foreground colour so they inherit the
  theme's default text colour (near-black on light, near-white on dark). Only the "meaningful"
  tokens carry colour, and those hues are picked from a Solarized-style palette chosen to stay
  legible against either a light or a dark background (no washed-out pastels, no near-black inks).
-->
<NotepadPlus>
    <UserLang name="Kirito" ext="ki" udlVersion="2.1">
        <Settings>
            <Global caseIgnored="no" allowFoldOfComments="no" foldCompact="no" forcePureLC="0" decimalSeparator="0" />
            <Prefix Keywords1="no" Keywords2="no" Keywords3="no" Keywords4="no" Keywords5="no" Keywords6="no" Keywords7="no" Keywords8="no" />
        </Settings>
        <KeywordLists>
            <Keywords name="Comments">00# 01 02 03 04</Keywords>
            <Keywords name="Numbers, prefix1">0x 0X 0o 0O 0b 0B</Keywords>
            <Keywords name="Numbers, prefix2"></Keywords>
            <Keywords name="Numbers, extras1">.</Keywords>
            <Keywords name="Numbers, extras2">e E _ a b c d f A B C D F</Keywords>
            <Keywords name="Numbers, suffix1"></Keywords>
            <Keywords name="Numbers, suffix2"></Keywords>
            <Keywords name="Numbers, range">+ -</Keywords>
            <Keywords name="Operators1">+ - * / % = &lt; &gt; ! : ( ) [ ] { } , . | &amp;</Keywords>
            <Keywords name="Operators2"></Keywords>
            <Keywords name="Folders in code1, open"></Keywords>
            <Keywords name="Folders in code1, middle"></Keywords>
            <Keywords name="Folders in code1, close"></Keywords>
            <Keywords name="Folders in code2, open"></Keywords>
            <Keywords name="Folders in code2, middle"></Keywords>
            <Keywords name="Folders in code2, close"></Keywords>
            <Keywords name="Folders in comment, open"></Keywords>
            <Keywords name="Folders in comment, middle"></Keywords>
            <Keywords name="Folders in comment, close"></Keywords>
            <Keywords name="Keywords1">and as assert break case catch class continue default discard elif else finally for if in not or pass return switch throw todo try var while with Function</Keywords>
            <Keywords name="Keywords2">True False None self</Keywords>
            <Keywords name="Keywords3">Any Array Bool Dict Float Integer List Set String</Keywords>
            <Keywords name="Keywords4">abs all any bin bitand bitnot bitor bitxor chr divmod enumerate filter format hex id import inspect isinstance len map max min oct ord pow range reversed round shl shr sorted sum type zip</Keywords>
            <Keywords name="Keywords5"></Keywords>
            <Keywords name="Keywords6"></Keywords>
            <Keywords name="Keywords7"></Keywords>
            <Keywords name="Keywords8"></Keywords>
            <Keywords name="Delimiters">00&quot; 01\ 02&quot; 03f&quot; 04\ 05&quot; 06 07 08</Keywords>
        </KeywordLists>
        <Styles>
            <!-- Neutral tokens omit fgColor/bgColor: they inherit the theme's text + background. -->
            <WordsStyle name="DEFAULT" fontStyle="0" nesting="0" />
            <WordsStyle name="OPERATORS" fontStyle="0" nesting="0" />
            <!-- Comments: muted slate, italic. Mid-tone grey reads on light and dark alike. -->
            <WordsStyle name="COMMENTS" fgColor="708890" fontStyle="2" nesting="0" />
            <WordsStyle name="LINE COMMENTS" fgColor="708890" fontStyle="2" nesting="0" />
            <!-- Numbers: magenta literal. -->
            <WordsStyle name="NUMBERS" fgColor="D33682" fontStyle="0" nesting="0" />
            <!-- Keywords / control flow: green, bold. -->
            <WordsStyle name="KEYWORDS1" fgColor="859900" fontStyle="1" nesting="0" />
            <!-- Constants True/False/None/self: orange, bold. -->
            <WordsStyle name="KEYWORDS2" fgColor="CB4B16" fontStyle="1" nesting="0" />
            <!-- Built-in types: amber, bold. -->
            <WordsStyle name="KEYWORDS3" fgColor="B58900" fontStyle="1" nesting="0" />
            <!-- Built-in functions: blue. -->
            <WordsStyle name="KEYWORDS4" fgColor="268BD2" fontStyle="0" nesting="0" />
            <!-- Strings + f-strings: cyan. -->
            <WordsStyle name="DELIMITERS1" fgColor="2AA198" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS2" fgColor="2AA198" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS3" fontStyle="0" nesting="0" />
        </Styles>
    </UserLang>
</NotepadPlus>
