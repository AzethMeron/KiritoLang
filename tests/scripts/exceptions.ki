# Exceptions: raise, try/except/finally, typed handlers, error catching.
var io = import("io")

class ValueError:
    var _init_ = Function(self, msg):
        self.msg = msg

var safeDivide = Function(a, b):
    try:
        return a / b
    except as e:
        return "error: " + e

io.print(safeDivide(10, 2))      # 5.0
io.print(safeDivide(10, 0))      # error: division by zero

var validate = Function(age):
    if age < 0:
        raise ValueError("age cannot be negative")
    return age

try:
    validate(-5)
except ValueError as e:
    io.print("caught: " + e.msg)  # caught: age cannot be negative

var log = []
try:
    log.append("try")
    raise "boom"
except:
    log.append("except")
finally:
    log.append("finally")
io.print(log)                    # [try, except, finally]
